Options -Indexes

# Disable direct access to sensitive folders
<FilesMatch "\.(sql|json|md|lock)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to config and vendor directories
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^vendor/ - [F,L]
</IfModule>

# PHP settings
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 120
    php_value memory_limit 256M
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Prevent access to uploads/exports folder directly
<FilesMatch "\.(xlsx|xls)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
